{
  "name": "cashew",
  "version": "0.1.0",
  "private": true,
  "description": "A Pi-based personal agent desktop app.",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter @cashew/desktop dev",
    "build": "pnpm --filter @cashew/desktop build",
    "preview": "pnpm --filter @cashew/desktop preview",
    "package": "pnpm --filter @cashew/desktop package",
    "make": "pnpm --filter @cashew/desktop make",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "protobufjs"
    ]
  }
}
