{
  "name": "@cashew/desktop",
  "productName": "Cashew",
  "version": "0.1.0",
  "description": "A Pi-based personal agent desktop app.",
  "main": "out/main/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "build:daemon": "cd ../daemon && pnpm build",
    "preview": "electron-vite preview",
    "stage:node": "node scripts/stage-node-runtime.mjs",
    "prepackage": "pnpm stage:node && pnpm build && pnpm build:daemon",
    "package": "pnpm prepackage && electron-builder --dir",
    "make": "pnpm prepackage && electron-builder",
    "publish": "pnpm prepackage && electron-builder --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": {
    "name": "戈德斯文",
    "email": "mrgoethe0126@gmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.cashew.app",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../daemon/out",
        "to": "daemon"
      },
      {
        "from": "../daemon/package.json",
        "to": "daemon/package.json"
      },
      {
        "from": "build/node",
        "to": "node"
      }
    ],
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@cashew/shared": "workspace:*",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0"
  }
}
