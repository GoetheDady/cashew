{
  "name": "@cashew/desktop",
  "productName": "Cashew",
  "version": "0.1.0",
  "description": "A Pi-based personal agent desktop app.",
  "main": "out/main/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "pnpm build && electron-builder --dir",
    "make": "pnpm build && electron-builder",
    "publish": "pnpm build && electron-builder --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": {
    "name": "戈德斯文",
    "email": "mrgoethe0126@gmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.cashew.app",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@cashew/agent": "workspace:*",
    "@cashew/shared": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
